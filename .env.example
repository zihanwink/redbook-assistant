# 应用配置
PORT=3000
NODE_ENV=production

# JWT 密钥（部署时务必修改为随机字符串）
JWT_SECRET=your-secret-key-change-this-in-production

# 管理员密钥
ADMIN_SECRET=redbook-admin-key

# MongoDB 连接字符串（留空则使用 JSON 文件存储）
# 免费 MongoDB Atlas: https://www.mongodb.com/cloud/atlas/register
MONGODB_URI=

# DeepSeek API（可选，用户可在前端自行配置）
DEEPSEEK_API_KEY=

# 前端地址（用于 CORS）
FRONTEND_URL=*
